{% extends 'base.html.twig' %}

{% block title %}Art mathématique - Figure 3{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    /* Classe spécifique pour explorer l'image sans la compresser */
    .viewport-fractale {
        width: 100%;
        height: 70vh;
        overflow: auto;
        border: 2px solid #333;
        background-color: #f8f9fa;
        margin-top: 1rem;
    }
</style>

<div class="example-wrapper">
    <main id="fig3">
        <h1>Paramètres :</h1>
        <form method="post" action="{{ path('fig-trois') }}">
            <div>
                <label for="depth" class="form-label">Profondeur</label>
                <input type="range" class="form-range" min="30" max="100" step="1" id="depth" name="DEPTH">
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary" name="calculer" value="1">Calculer</button>
                <button type="submit" class="btn btn-danger" name="imprimer" value="1">Imprimer</button>
            </div>
        </form>
    </main>
</div>

{% if fichier is not empty %}
<div class="container-fluid mt-4 mb-5">
    <h2>Résultat brut (4000x4000) :</h2>
    <div class="viewport-fractale">
        <img src="{{ asset(fichier) }}?v={{ date().timestamp }}" style="max-width: none;" alt="Rendu de la figure 3">
    </div>
</div>
{% endif %}

{% endblock %}