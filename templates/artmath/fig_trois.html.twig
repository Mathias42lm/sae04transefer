{% extends 'base.html.twig' %}

{% block title %}Art mathématique - Figure 2{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>
<div class="example-wrapper">
    <main id="fig2">
        <a class="navbar-brand" href="#fig2">Figure 3</a>
        <h1>Paramètres :</h1>
        <form method="post" action="{{ path('fig-trois') }}">
            <div>
                <label for="depth" class="form-label">Profondeur</label>
                <input type="range" class="form-range" min="0" max="10" step="1" id="depth" name="depth">
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary" name="calculer" value="1">Calculer</button>
                <button type="submit" class="btn btn-danger" name="imprimer" value="1">Imprimer</button>
            </div>
        </form>

        {% if fichier is not empty %}
            <h1 class="mt-4">Résultat :</h1>
            <img src="{{ fichier }}" width="100%" alt="Rendu de la figure 2">
        {% endif %}
    </main>
</div>

{% endblock %}