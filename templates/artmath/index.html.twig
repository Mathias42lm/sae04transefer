{% extends 'base.html.twig' %}

{% block title %}Sélection de la Figure{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0 text-center">Sélection de la Figure</h4>
                </div>
                <div class="card-body">
                    <!-- d-grid pour forcer les boutons à prendre toute la largeur et gap-3 pour l'espacement -->
                    <div class="d-grid gap-3">
                        <a href="{{ path('app_fig_un') }}" class="btn btn-outline-info btn-lg">Afficher la Figure 1</a>
                        <a href="{{ path('app_fig_2') }}" class="btn btn-outline-info btn-lg">Afficher la Figure 2</a>
                        <a href="{{ path('app_fig_3') }}" class="btn btn-outline-info btn-lg">Afficher la Figure 3</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}