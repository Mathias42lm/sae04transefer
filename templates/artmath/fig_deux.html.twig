{% extends 'base.html.twig' %}

{% block title %}Art mathématique - Figure 2{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <main id="fig2">
        <a class="navbar-brand" href="#fig2">Figure 2</a>
        <h1>Paramètres :</h1>
        <form method="post" action="{{ path('fig-deux') }}">
            <div>
                <label for="hasard" class="form-label">Hasard</label>
                <input type="range" class="form-range" min="0" max="1" step="0.1" id="hasard" name="hasard">
                
                <label for="hasardangle" class="form-label">Hasard angle</label>
                <input type="range" class="form-range" min="0" max="1" step="0.1" id="hasardangle" name="hasardangle">
                
                <label for="nbcolonnes" class="form-label">Nb Colonnes</label>
                <input type="range" class="form-range" min="1" max="10" step="1" id="nbcolonnes" name="nbcolonnes">
                
                <label for="nblignes" class="form-label">Nb Lignes</label>
                <input type="range" class="form-range" min="1" max="10" step="1" id="nblignes" name="nblignes">
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary" name="calculer" value="1">Calculer</button>
                <button type="submit" class="btn btn-danger" name="imprimer" value="1">Imprimer</button>
            </div>
        </form>

        {% if fichier is not empty %}
            <h1 class="mt-4">Résultat :</h1>
            <img src="{{ fichier }}" width="100%" alt="Rendu de la figure 2">
        {% endif %}
    </main>
</div>
<!-- Correction: Ajout du endblock manquant -->
{% endblock %}